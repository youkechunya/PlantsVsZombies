  plantDescription: "\u5411\u65E5\u8475\u662F\u4F60\u6536\u96C6\u989D\u5916\u9633\u5149\u5FC5\u4E0D\u53EF\u5C11\u7684\u690D\u7269\u3002\u4E3A\u4EC0\u4E48\u4E0D\u591A\u79CD\u690D\u4E00\u4E9B\u5462\uFF1F"

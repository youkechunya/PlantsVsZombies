  plantName: "\u6A31\u6843\u70B8\u5F39"
  plantDescription: "\u6A31\u6843\u70B8\u5F39\u80FD\u591F\u70B8\u98DE\u4E00\u7247\u533A\u57DF\u5185\u7684\u6240\u6709\u50F5\u5C38\u3002\u4ED6\u4EEC\u7684\u5F15\u7EBF\u5F88\u77ED\uFF0C\u6240\u4EE5\uFF0C\u628A\u4ED6\u4EEC\u79CD\u5728\u79BB\u50F5\u5C38\u8FD1\u4E00\u4E9B\u7684\u4F4D\u7F6E\u5427\u3002"
  plantData: "\u4F24\u5BB3\uFF1A1800\uFF08\u7070\u70EC\uFF09\n\u8303\u56F4\uFF1A3x3\uFF08\u534A\u5F841.5\u683C\u7684\u5706\uFF09"

  plantName: "\u571F\u8C46\u5730\u96F7"
  plantDescription: "\u571F\u8C46\u5730\u96F7\u80FD\u591F\u7ED9\u4E88\u654C\u4EBA\u81F4\u547D\u4E00\u51FB\uFF0C\u4F60\u5E94\u5F53\u628A\u4ED6\u4EEC\u79CD\u5728\u50F5\u5C38\u7684\u524D\u9762\u2014\u2014\u4EE5\u4FBF\u4ED6\u4EEC\u5728\u63A5\u89E6\u50F5\u5C38\u65F6\u8D77\u7206\u3002"
  plantData: "\u4F24\u5BB3\uFF1A1800\n\u8303\u56F4\uFF1A\u534A\u5F840.74\u683C\n\u7279\u70B9\uFF1A\u79CD\u690D\u540E\u9700\u8981\u7B49\u5F8515~17\u79D2\u624D\u4F1A\u51FA\u571F"
